{
  "compilerOptions": {
    "target": "es2025",
    "lib": ["dom", "dom.iterable", "es2025"],
    "module": "ESNext",
    "skipLibCheck": true,
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Levels strict of Big Tech */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* 🚀 ALIAS CONFIGURATED STYLE TS 6.0+ (without baseUrl) */
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["./src/app/*"],
      "@features/*": ["./src/features/*"],
      "@shared/*": ["./src/shared/*"],
      "@images/*": ["./src/shared/assets/images/*"]
    }
  },
  "include": ["src"]
}